generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String? // nullable for OAuth users
  name     String?
  image    String?

  authProvider AuthProvider @default(EMAIL)
  providerId   String? // Google "sub" ID

  role       UserRole @default(USER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)

  ownedProjects Project[]
  providedUsers ProjectUser[] @relation("UserProvidedProjectUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([providerId])
}

model Project {
  id          String        @id @default(uuid())
  ownerId     String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)

  owner   User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members ProjectUser[]
  apiKeys ProjectApiKey[]
  jwtKeys ProjectJwtKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      Logs[]

  @@index([ownerId])
}

model ProjectApiKey {
  id        String @id @default(uuid())
  projectId String

  apiKey        String @unique
  secretKeyHash String

  environment ApiEnvironment
  isActive    Boolean        @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectJwtKey {
  id        String @id @default(uuid())
  projectId String

  kid                 String @unique
  publicKey           String
  privateKeyEncrypted String

  algorithm JwtAlgorithm @default(RS256)
  isActive  Boolean      @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectUser {
  id         String @id @default(uuid())
  projectId  String
  providerId String

  name         String
  email        String
  password     String
  role         ProjectRole
  tokenVersion Int         @default(0)
  isVerified   Boolean     @default(false)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider User    @relation("UserProvidedProjectUsers", fields: [providerId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  @@unique([projectId, email])
  @@index([providerId])
}

model Logs {
  id         String @id @default(uuid())
  projectId  String
  providerId String

  endpoint    String
  requestType String
  statusCode  Int
  message     String
  error       Boolean

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
}

enum ApiEnvironment {
  DEVELOPMENT
  PRODUCTION
}

enum JwtAlgorithm {
  RS256
}
